{
  "redirects": [
    {
      "source": "https://www.luridone.it/:path*",
      "destination": "https://luridone.it/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
