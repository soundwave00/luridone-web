---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/sections.css';

import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Manifesto from '../components/Manifesto.astro';
import Features from '../components/Features.astro';
import ProblemSolution from '../components/ProblemSolution.astro';
import Stats from '../components/Stats.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>LURIDONE — La guida ai posti luridi più buoni di Milano</title>
    <meta name="description" content="Mappa, recensioni vere e community dei baracchini, trattorie e posti luridi di Milano. Se non è su Google, è Luridone." />

    <!-- Open Graph -->
    <meta property="og:title" content="LURIDONE — Milano Lurida e bellissima" />
    <meta property="og:description" content="La guida ai posti luridi più buoni di Milano." />
    <meta property="og:image" content="https://luridone.it/assets/og-image.jpg" />
    <meta property="og:url" content="https://luridone.it" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:site_name" content="LURIDONE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="LURIDONE — Milano Lurida e bellissima" />
    <meta name="twitter:description" content="La guida ai posti luridi più buoni di Milano." />
    <meta name="twitter:image" content="https://luridone.it/assets/og-image.jpg" />

    <link rel="canonical" href="https://luridone.it" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <meta name="theme-color" content="#7B1010" />

    <!-- Google Fonts — async load to avoid render blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="preload"
      as="style"
      crossorigin="anonymous"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <Hero />
    <Marquee />
    <Manifesto />
    <Features />
    <ProblemSolution />
    <Stats />
    <FinalCTA />
    <Footer />

    <script>
      import '../scripts/main.ts';
    </script>
  </body>
</html>
