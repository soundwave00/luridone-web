---
---
<header class="hero" data-screen-label="Hero">
  <video
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster="/assets/hero-poster.jpg"
  >
    <source src="/assets/hero.webm" type="video/webm" />
    <source src="/assets/hero.mp4" type="video/mp4" />
  </video>
  <div class="veil"></div>
  <div class="grain" aria-hidden="true"></div>

  <nav class="topbar">
    <div class="brandmark">Luridone</div>
    <a class="mini" href="#download">Scarica l'app</a>
  </nav>

  <div class="hero-inner">
    <div class="hero-row">
      <h1>Luridone</h1>
    </div>
    <div class="subband">
      <span class="line">
        <span class="crimson">Milano </span><span class="gold">Lurida</span><span class="crimson"> e bellissima</span>
      </span>
    </div>
    <p class="lede">
      La guida ai baracchini, trattorie e posti luridi più buoni di Milano.
      Se non è su Google, è Luridone.
    </p>
    <div class="pills">
      <span class="pill"><span class="dot"></span>iOS + Android</span>
      <span class="pill"><span class="dot"></span>Community-driven</span>
      <span class="pill"><span class="dot"></span>Mappa calda</span>
    </div>
    <a class="btn btn-fill" href="#download">Scarica l'app</a>
  </div>

  <div class="scroll-cue" aria-hidden="true">Scrolla<span class="arrow"></span></div>
</header>
