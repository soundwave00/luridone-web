---
import SauceSVG from './SauceSVG.astro';
---
<section class="finalcta" id="download">
  <SauceSVG
    id="sauce3"
    sauceStyle="bottom:30px;left:50%;transform:translateX(-50%);width:760px;height:200px;"
    viewBox="0 0 760 200"
    d="M20,120 C160,20 240,200 380,100 S600,10 740,110"
  />
  <div class="wrap">
    <h2 class="reveal">
      Scaricalo.<br />
      È gratis. <span class="gold">È lurido.</span>
    </h2>
    <p class="sub reveal">Disponibile su iOS e Android</p>
    <div class="cta-btns reveal">
      <a class="btn btn-out" href="#">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16.4 12.9c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.8-3.5.8-.7 0-1.8-.8-3-.8-1.5 0-2.9.9-3.7 2.2-1.6 2.7-.4 6.8 1.1 9 .7 1.1 1.6 2.3 2.8 2.2 1.1 0 1.5-.7 2.9-.7 1.3 0 1.7.7 2.9.7 1.2 0 2-1.1 2.7-2.1.8-1.2 1.2-2.4 1.2-2.4-.1 0-2.3-.9-2.3-3.5Zm-2.3-6.5c.6-.8 1-1.8.9-2.9-.9 0-2 .6-2.6 1.3-.6.7-1.1 1.7-.9 2.7 1 .1 2-.5 2.6-1.1Z"/>
        </svg>
        App Store
      </a>
      <a class="btn btn-out" href="#">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M4 3.2v17.6c0 .4.4.7.8.5l9.5-8.8c.3-.3.3-.7 0-1L5 2.7c-.5-.3-1-.1-1 .5Z" opacity=".55"/>
          <path d="M14.3 11.5 17 9 5.8 2.6c-.3-.2-.7-.2-.9 0l9.4 8.9Z"/>
          <path d="M14.3 12.5 5 21.4c.2.2.6.2.9 0L17 15l-2.7-2.5Z"/>
          <path d="M17 9l3.6 2.1c.6.4.6 1.4 0 1.8L17 15l-2.7-2.5L17 9Z" opacity=".8"/>
        </svg>
        Google Play
      </a>
    </div>
    <img
      class="mascot-big"
      src="/assets/mascot.png"
      alt="Mascotte Luridone"
      loading="lazy"
      decoding="async"
    />
  </div>
</section>
